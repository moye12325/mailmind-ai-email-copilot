# MailMind local development environment template.
#
# This file may contain example values only. Do not put real tokens, API keys,
# OAuth secrets, or a real APP_ENCRYPTION_KEY in .env.example.
# Real local configuration belongs in .env, and .env must stay ignored by Git.

APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000

APP_SECRET_KEY=change-me
APP_ENCRYPTION_KEY=change-me-32-byte-base64
APP_ENCRYPTION_KEY_VERSION=v1

DATABASE_URL=postgresql+psycopg://mailmind:mailmind@localhost:5432/mailmind
REDIS_URL=redis://localhost:6379/0

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/gmail/callback

LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2

AI_PROVIDER_MODE=env
AI_DEFAULT_PROVIDER=primary
AI_PROVIDER_ORDER=primary,backup

AI_PROVIDER_PRIMARY_TYPE=openai_compatible
AI_PROVIDER_PRIMARY_BASE_URL=https://api.example.com/v1
AI_PROVIDER_PRIMARY_API_KEY=replace-with-your-key
AI_PROVIDER_PRIMARY_MODEL=replace-with-model
AI_PROVIDER_PRIMARY_TIMEOUT_SECONDS=60
AI_PROVIDER_PRIMARY_MAX_RETRIES=2

AI_PROVIDER_BACKUP_TYPE=openai_compatible
AI_PROVIDER_BACKUP_BASE_URL=https://api.backup.example.com/v1
AI_PROVIDER_BACKUP_API_KEY=replace-with-your-backup-key
AI_PROVIDER_BACKUP_MODEL=replace-with-backup-model
AI_PROVIDER_BACKUP_TIMEOUT_SECONDS=60
AI_PROVIDER_BACKUP_MAX_RETRIES=1

DEFAULT_TIMEZONE=Asia/Shanghai

DIGEST_AUTO_GENERATE=true
DIGEST_GENERATE_TIME=08:00

POSTGRES_DB=mailmind
POSTGRES_USER=mailmind
POSTGRES_PASSWORD=mailmind
