graph TB
    Browser["🌐 Browser<br/><b>Next.js 15 · React 19 · TypeScript</b><br/><i>App Router · CSS Custom Properties</i>"]

    subgraph MailMind["MailMind System"]
        API["⚡ FastAPI Backend<br/><b>Python 3.11+ · SQLAlchemy 2.0</b><br/><i>Auth · Mailbox · Digest · Email · Jobs</i>"]
        Worker["⚙️ Celery Worker<br/><b>Async Job Execution</b><br/><i>Email Sync · Digest Generation</i>"]
