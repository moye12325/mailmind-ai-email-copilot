        Redis[("🔴 Redis 7<br/><b>Broker · Result Backend</b><br/><i>Task Queue · Distributed Locks</i>")]
    end

    subgraph External_Services["External Services"]
        Gmail["📧 Gmail API<br/><b>OAuth 2.0 · REST</b><br/><i>Full Email Access</i>"]
